[Unit]
Description=LegationesAdVaticanum Flask application
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/srv/poselstwa
Environment="POSELSTWA_SECRET_KEY=zmien-to-na-wlasny-sekret"
ExecStart=/srv/poselstwa/venv/bin/gunicorn -w 2 -b 127.0.0.1:8092 run:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
